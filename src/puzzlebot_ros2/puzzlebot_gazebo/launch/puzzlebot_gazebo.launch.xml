<launch>
    <let name="world" value="$(find-pkg-share puzzlebot_gazebo)/worlds/maze.world"/>
    <let name="puzzlebot_description_path" value="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml"/>
    <let name="gazebo_bridge_config_path" value="$(find-pkg-share puzzlebot_gazebo)/config/gazebo_bridge.yaml"/>
    <let name="x_pose" value="1.35"/>
    <let name="y_pose" value="0.0"7>
    <arg name="use_sim_time" default="true"/>
    <arg name="headless" default="false"/>
    
    <include if="$(not $(var headless))" file="$(find_pkg_share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(var world) -r"/>
    </include>

    <include file="$(var puzzlebot_description_path)">
        <args name="use_sim_time" value="$(var use_sim_time)"/>
    </include>

    <node pkg="ros_gz_sim" exec="create" output="screen" args="-name puzzlebot -topic robot_description -x $(var x_pose) -y $(var y_pose) -z 0.01 -Y 3.1416"/>

    <node pkg="ros_gz_bridge" exec="parameter_brigde" output="screen">
        <param name="config_file" value="$(var gazebo_bridge_config_path)" />
    </node>

</launch>