<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- BASE FOOTPRINT -->

   <link name="base_footprint"></link>

    <!-- BASE LINK -->

   <link name="base_link">
        <visual>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/>
            </geometry>
            <material name="yellow">
                <color rgba="0.8 0.8 0.05 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="base_link_joint" type="fixed">
        <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <!-- LEFT WHEEL -->

    <link name="left_wheel_link">
        <visual>
            <origin rpy="1.57 0.0 0.0"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
            </geometry>
            <material name="yellow">
                <color rgba="0.8 0.8 0.05 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0.052 0.095 -0.0025"/>
        <axis xyz="0.0 1.0 0.0"/>
        
    </joint>

    <!-- RIGHT WHEEL -->

    <link name="right_wheel_link">
        <visual>
            <origin rpy="-1.57 0.0 0.0"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
            </geometry>
            <material name="yellow">
                <color rgba="0.8 0.8 0.05 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0.052 -0.095 -0.0025"/>
        <axis xyz="0.0 1.0 0.0"/>
        
    </joint>

    <!-- CASTER  WHEEL -->

    <link name="caster_link">
        <visual>
            <origin xyz="0.0 0.0 -0.015"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl"/>
            </geometry>
            <material name="yellow">
                <color rgba="0.8 0.8 0.05 1.0"/>
            </material>
        </visual>
    </link>

    <joint name="caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_link"/>
        <origin xyz="-0.095 0.0 -0.03"/>
    </joint>

</robot>